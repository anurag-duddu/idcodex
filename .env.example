# ID Codex — environment template. Copy values into a gitignored `.env`.
# (The real .env already has NOTION_API_KEY + Neon DATABASE_URL[_UNPOOLED].)

# ───────────────────────── App ─────────────────────────
APP_URL=http://localhost:3000
AUTH_SECRET=            # `openssl rand -base64 32`

# ──────────────── Database: Neon Postgres ────────────────
DATABASE_URL=          # Neon → Connection Details → pooled connection string
DATABASE_URL_UNPOOLED= # Neon → "Direct connection" (used for migrations)

# ──────────────── File storage: Cloudflare R2 ────────────────
R2_ACCOUNT_ID=         # Cloudflare account ID
R2_ACCESS_KEY_ID=      # R2 → Manage API Tokens → S3-compatible token
R2_SECRET_ACCESS_KEY=
R2_BUCKET=idcodex-files
R2_ENDPOINT=           # https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com

# ──────────────── Migration / seeding (local) ────────────────
NOTION_API_KEY=        # existing Notion integration key (ntn_...)

# ──────────────── Production email (optional) ────────────────
# RESEND_API_KEY=
# AUTH_EMAIL_FROM=ID Codex <login@idcodex.org>

# ──────────────── AI assistant (Slice 3 — later) ────────────────
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
